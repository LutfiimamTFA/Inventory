rules_version = '2';

// Firestore rules AssetView.
// Berjalan di project Firebase HRP yang sama. Rules ini HANYA menambah
// aturan untuk collection AssetView (assets, asset_categories, asset_users, dst)
// dan TIDAK mengubah/menghapus aturan collection HRP yang sudah ada — gabungkan
// blok match di bawah ini ke dalam firestore.rules HRP yang sudah berjalan,
// jangan menimpanya.
//
// AssetView bersifat mandiri: akses & role ditentukan sepenuhnya dari
// collection asset_users, BUKAN dari data karyawan HRP. HRP hanya dipakai
// sebagai sumber Firebase Auth (project yang sama).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Daftar email bootstrap Super Admin pertama AssetView.
    // WAJIB disamakan dengan NEXT_PUBLIC_ASSETVIEW_SUPER_ADMIN_EMAILS di .env.local.
    function isBootstrapSuperAdminEmail() {
      return request.auth.token.email in [
        "super_admin@gmail.com"
      ];
    }

    function assetUserDoc() {
      return get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data;
    }

    function isActiveAssetUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/asset_users/$(request.auth.uid)) &&
        assetUserDoc().status == "active";
    }

    function isSuperAdmin() {
      return isActiveAssetUser() && assetUserDoc().role == "super_admin";
    }

    function isAssetAdmin() {
      return isActiveAssetUser() && assetUserDoc().role == "asset_admin";
    }

    function isAssetViewSuperAdmin() {
      return isSuperAdmin();
    }

    function isAssetViewAssetAdmin() {
      return isAssetAdmin();
    }

    function isAssetViewItTeam() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/asset_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data.role == "it_team"
        && get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data.status == "active";
    }

    function isAssetBootstrapSuperAdminEmail() {
      return isBootstrapSuperAdminEmail();
    }

    function isAssetQhseAdmin() {
      return isAssetViewAssetAdmin() || isAssetAdmin();
    }

    function isManager() {
      return isSuperAdmin() || isAssetAdmin();
    }

    // Section G — Asset Finance: role khusus data finance (harga, invoice,
    // vendor, sumber dana, dll), TIDAK boleh sentuh lokasi/custodian/
    // pemakaian/maintenance. Asset Admin/QHSE boleh lihat data finance
    // read-only (canViewAssetFinance), tapi TIDAK boleh mengeditnya lewat
    // rule ini (edit finance cuma lewat canEditAssetFinance).
    function isAssetViewFinance() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/asset_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data.role == "asset_finance"
        && get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data.status == "active";
    }

    function canViewAssetFinance() {
      return isAssetViewSuperAdmin()
        || isAssetViewFinance()
        || isAssetQhseAdmin();
    }

    function canEditAssetFinance() {
      return isAssetViewSuperAdmin()
        || isAssetViewFinance();
    }

    // Field finance yang boleh diubah Asset Finance — TIDAK termasuk lokasi,
    // custodian, currentHolder, status pemakaian, maintenance, kategori
    // utama, nama/kode aset (lihat section G spec).
    function isAssetFinanceUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAssetViewFinance() &&
        changed.hasOnly([
          "purchaseDate", "purchasePrice", "vendorName", "invoiceNumber",
          "fundingSource", "purchaseMethod", "estimatedUsefulLife", "financeNotes",
          "financeStatus", "financeUpdatedAt", "financeUpdatedByUid", "financeUpdatedByName",
          "invoiceFileId", "invoiceDriveFileId", "invoiceFileUrl", "invoiceFileName",
          "invoiceMimeType", "invoiceSize", "invoiceUploadedAt",
          "updatedAt", "updatedByUid", "updatedByName"
        ]);
    }

    // PIC Lokasi — orang yang bertanggung jawab mendata/mengawasi aset di
    // suatu lokasi (Gedung/Lantai/Ruangan/Area), BEDA dengan
    // custodian/currentHolder yang menunjuk pemegang BARANG tertentu. PIC
    // Lokasi ditugaskan lewat asset_locations (picUid) oleh Super
    // Admin/Asset Admin — role ini sendiri cuma dikelola lewat User Access.
    function isLocationPic() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/asset_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data.role == "location_pic"
        && get(/databases/$(database)/documents/asset_users/$(request.auth.uid)).data.status == "active";
    }

    // Scope aset PIC Lokasi ditentukan dari areaPicUid, yang diisi OTOMATIS
    // di client (resolveAreaPic di lib/locations.ts) lewat cascade Area >
    // Ruangan > Lantai > Gedung saat aset dibuat/diedit — jadi cukup
    // dicocokkan langsung ke sini tanpa perlu get() berlapis ke
    // asset_locations. PIC Lokasi TIDAK boleh sentuh field finance (lihat
    // isAssetFinanceUpdate) lewat rule ini.
    function isLocationPicCreate() {
      return isLocationPic() && request.resource.data.areaPicUid == request.auth.uid;
    }

    function isLocationPicUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let financeFields = [
        "purchaseDate", "purchasePrice", "vendorName", "invoiceNumber",
        "fundingSource", "purchaseMethod", "estimatedUsefulLife", "financeNotes",
        "financeStatus", "financeUpdatedAt", "financeUpdatedByUid", "financeUpdatedByName",
        "invoiceFileId", "invoiceDriveFileId", "invoiceFileUrl", "invoiceFileName",
        "invoiceMimeType", "invoiceSize", "invoiceUploadedAt"
      ];
      return isLocationPic()
        && resource.data.areaPicUid == request.auth.uid
        && request.resource.data.areaPicUid == request.auth.uid
        && !changed.hasAny(financeFields);
    }

    function canViewAssetMaintenance() {
      return isAssetViewSuperAdmin()
        || isAssetQhseAdmin()
        || isAssetViewItTeam()
        || isAssetBootstrapSuperAdminEmail();
    }

    function canEditMaintenanceSchedule() {
      return isAssetQhseAdmin()
        || isAssetViewSuperAdmin()
        || isAssetBootstrapSuperAdminEmail();
    }

    function isAssignedMaintenanceTechnician(data) {
      return isSignedIn()
        && isAssetViewItTeam()
        && (
          data.get("assignedToUid", "") == request.auth.uid ||
          data.get("technicianUid", "") == request.auth.uid ||
          data.get("assignedTechnicianUid", "") == request.auth.uid
        );
    }

    // Section K — validasi transisi status Maintenance Rutin per role, supaya
    // QHSE tidak bisa lompat langsung ke status kerja Tim IT (atau sebaliknya)
    // hanya karena canEditMaintenanceSchedule()/isTechnicianMaintenanceUpdate()
    // mengizinkan field "status" diubah. Field lain (bukan status) tetap ikut
    // aturan lama masing-masing.
    function routineStatusTransition() {
      return resource.data.get("status", "") + "->" + request.resource.data.get("status", "");
    }

    function isQhseRoutineStatusUpdate() {
      return canEditMaintenanceSchedule()
        && routineStatusTransition() in [
          "created->cancelled",
          "report_submitted->waiting_qhse_review",
          "waiting_qhse_review->completed",
          "waiting_qhse_review->revision_requested",
          "waiting_qhse_review->needs_follow_up",
          "waiting_qhse_review->cancelled",
          "needs_follow_up->completed",
          "needs_follow_up->cancelled",
          "needs_follow_up->revision_requested",
          "revision_requested->cancelled"
        ];
    }

    function isItRoutineStatusUpdate() {
      return isAssignedMaintenanceTechnician(resource.data)
        && routineStatusTransition() in [
          "created->accepted",
          "accepted->scheduled_by_it",
          "scheduled_by_it->in_progress",
          "in_progress->report_submitted",
          "revision_requested->in_progress",
          "revision_requested->report_submitted"
        ];
    }

    function isTechnicianMaintenanceUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return isAssignedMaintenanceTechnician(resource.data)
        && changed.hasOnly([
          "status",
          "statusLabel",
          "boardColumn",
          "movedAt",
          "movedByUid",
          "movedByName",

          "acceptedAt",
          "acceptedByUid",
          "acceptedByName",

          "plannedWorkDate",
          "plannedStartTime",
          "plannedEndTime",
          "plannedNote",
          "willInterruptUser",
          "scheduledByItAt",
          "scheduledByItUid",
          "scheduledByItName",

          "startedAt",
          "startedByUid",
          "startedByName",

          "report",
          "reportNote",
          "reportSummary",
          "reportConclusion",
          "reportRecommendation",
          "reportData",
          "reportSubmittedAt",
          "reportSubmittedByUid",
          "reportSubmittedByName",

          "previousStatus",
          "reopenedAt",
          "reopenedByUid",
          "reopenedByName",
          "reopenReason",
          "retryCount",

          "checklistResetAt",
          "checklistResetByUid",
          "checklistResetByName",
          "checklistResetReason",

          "hasFindings",
          "needsQhseReview",
          "followUpStatus",
          "lastFindingAt",
          "lastFindingByUid",
          "lastFindingByName",
          "lastActivityAt",
          "lastActivityByUid",
          "lastActivityByName",
          "lastActivityMessage",

          "updatedAt",
          "updatedByUid",
          "updatedByName"
        ]);
    }

    // asset_users: sumber tunggal role & status akses AssetView.
    match /asset_users/{uid} {
      allow read: if isActiveAssetUser();
      // Bootstrap: user boleh membuat dokumennya sendiri sebagai super_admin
      // HANYA saat dokumen belum ada dan emailnya ada di daftar bootstrap.
      allow create: if isSignedIn() && uid == request.auth.uid &&
        !exists(/databases/$(database)/documents/asset_users/$(uid)) &&
        isBootstrapSuperAdminEmail() &&
        request.resource.data.role == "super_admin" &&
        request.resource.data.status == "active";
      // Super Admin boleh membuat/mengubah dokumen user lain (Tambah User,
      // ubah role, aktif/nonaktif). User biasa hanya boleh update lastLoginAt
      // miliknya sendiri.
      allow create, update: if isSuperAdmin() ||
        (isActiveAssetUser() && uid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lastLoginAt"]));
      allow delete: if false;
    }

    match /asset_user_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    // employee_profiles / usersdev / users: hanya dipakai untuk dropdown
    // "Penanggung Jawab" di form aset, read-only, TIDAK dipakai untuk auth/role.
    match /{employeeCollection}/{uid} {
      allow read: if isActiveAssetUser() &&
        employeeCollection in ["employee_profiles", "usersdev", "users"];
      allow write: if false;
    }

    match /asset_categories/{categoryId} {
      allow read: if isActiveAssetUser();
      allow write: if isManager();
    }

    // asset_locations: Master Lokasi (Gedung/Lantai/Ruangan/Area). READ
    // dibuka untuk SIAPA SAJA yang sudah login (isSignedIn()), termasuk
    // staff HRP fallback yang belum punya dokumen asset_users sama sekali
    // (lihat isActiveAssetUser()) — mereka tetap butuh baca daftar lokasi
    // untuk memilih "lokasi masalah" di halaman Buat Laporan. Super Admin &
    // Asset Admin/QHSE tetap satu-satunya yang boleh create/update; hanya
    // Super Admin boleh hapus (UI sendiri tidak menyediakan hard delete,
    // hanya nonaktifkan).
    match /asset_locations/{locationId} {
      allow get, list: if isSignedIn();
      allow create, update: if isManager();
      allow delete: if isSuperAdmin();
    }

    // asset_location_logs: riwayat penugasan/perubahan/penghapusan PIC
    // Lokasi (section I) — cuma ditulis oleh Super Admin/Asset Admin lewat
    // Master Lokasi, sama seperti yang boleh mengubah asset_locations.
    match /asset_location_logs/{logId} {
      allow read: if isActiveAssetUser();
      allow create: if isManager();
      allow update, delete: if false;
    }

    // Custodian/currentHolder boleh menyerahkan-sementara & mengembalikan
    // aset "assigned_daily" sendiri (handoverTemporary/returnToCustodian di
    // lib/custodian-actions.ts) — TAPI TIDAK boleh mengubah custodianUid/
    // usageType (itu hanya lewat isManager(), lihat assignCustodian).
    function isCustodianOrHolderUsageUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let isCustodian = resource.data.get("custodianUid", "") == request.auth.uid;
      let isHolder = resource.data.get("currentHolderUid", "") == request.auth.uid;
      return isActiveAssetUser() && (isCustodian || isHolder) &&
        changed.hasOnly([
          "currentUsageStatus", "currentUsageStatusLabel",
          "currentHolderUid", "currentHolderName", "currentHolderEmail", "currentHolderDivision",
          "temporaryUseStartedAt", "temporaryUseExpectedReturnAt", "temporaryUseEndedAt",
          "temporaryUsePurpose", "temporaryUseNote", "currentUsageNote",
          "handedOverByUid", "handedOverByName",
          "returnedByUid", "returnedByName",
          "updatedAt"
        ]);
    }

    // Section L — akses PIC Lokasi berbasis FIELD ASSET (locationPicUid/
    // areaPicUid/allowedLocationPicUids), BUKAN role "location_pic". Ini
    // yang memungkinkan staff biasa yang ditunjuk PIC di Master Lokasi
    // (mis. Daniel) langsung dapat akses tanpa perlu ganti role lewat User
    // Access — beda dari isLocationPic()/isLocationPicCreate()/
    // isLocationPicUpdate() di atas yang masih role-gated (dipertahankan,
    // tidak dihapus, untuk akun yang literal berrole "location_pic").
    function isLocationPicForAsset(data) {
      return isSignedIn()
        && (
          data.get("locationPicUid", "") == request.auth.uid
          || data.get("areaPicUid", "") == request.auth.uid
          || request.auth.uid in data.get("allowedLocationPicUids", [])
        );
    }

    function isLocationPicCreateAsset() {
      return isSignedIn()
        && request.resource.data.get("createdFromLocationPic", false) == true
        && request.resource.data.get("locationPicUid", "") == request.auth.uid
        && request.auth.uid in request.resource.data.get("allowedLocationPicUids", []);
    }

    function isLocationPicAllowedAssetUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return isLocationPicForAsset(resource.data)
        && changed.hasOnly([
          "name", "assetName", "categoryId", "categoryName", "brandName", "model", "type", "serialNumber",
          "divisionId", "divisionName",

          "locationId", "location", "locationText",
          "buildingId", "buildingName", "floorId", "floorName", "roomId", "roomName", "areaId", "areaName",

          "trackingMode", "usageType", "usageTypeLabel",
          "custodianUid", "custodianName", "custodianEmail", "custodianDivision", "custodianRole",
          "currentHolderUid", "currentHolderName", "currentHolderEmail", "currentHolderDivision",
          "currentUsageStatus", "currentUsageStatusLabel",

          "assetStatus", "status", "condition", "conditionLabel", "isBorrowable",

          "photoUrl", "photoUrls", "imageUrl", "driveFileId", "driveUrl", "thumbnailUrl",

          "operationalNote", "note",

          "areaPicUid", "areaPicName", "areaPicEmail", "areaPicLocationId", "areaPicLocationName",
          "locationPicUid", "locationPicName", "locationPicEmail", "allowedLocationPicUids",

          "updatedAt", "updatedByUid", "updatedByName", "updatedByRole"
        ])
        && !changed.hasAny([
          "purchasePrice", "price", "assetValue", "purchaseDate", "vendorName", "invoiceNumber",
          "invoiceFileId", "invoiceUrl", "fundingSource", "purchaseMethod", "estimatedUsefulLife", "financeNote"
        ]);
    }

    match /assets/{assetId} {
      allow read: if isActiveAssetUser() || isLocationPicForAsset(resource.data);
      allow create: if isManager() || isLocationPicCreate() || isLocationPicCreateAsset();
      allow update: if isManager() ||
        isCustodianOrHolderUsageUpdate() ||
        isAssetFinanceUpdate() ||
        isLocationPicUpdate() ||
        isLocationPicAllowedAssetUpdate() ||
        (isActiveAssetUser() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["assetStatus", "condition", "currentBorrowingId",
                      "currentBorrowerUid", "currentBorrowerName",
                      "lastMaintenanceAt", "nextMaintenanceAt", "updatedAt"]));
      allow delete: if isSuperAdmin();
    }

    match /asset_borrowings/{borrowingId} {
      allow read: if isActiveAssetUser();
      allow create: if isActiveAssetUser() &&
        request.resource.data.borrowedByUid == request.auth.uid;
      allow update: if isManager() ||
        (isActiveAssetUser() && resource.data.borrowedByUid == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    match /asset_logs/{logId} {
      allow read: if isActiveAssetUser();
      allow create: if isActiveAssetUser();
      allow update, delete: if false;
    }

    function isManualWebIssueCreate() {
      return isSignedIn()
        && request.resource.data.source == "manual_web"
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.reportedByUid == request.auth.uid
        && request.resource.data.reportType is string
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.locationId is string
        && request.resource.data.locationText is string
        && request.resource.data.status == "reported";
    }

    // Section D/G perbaikan alur laporan kendala staff — 3 transisi status
    // yang boleh staff pelapor lakukan SENDIRI (bukan lewat dropdown bebas,
    // tapi lewat tombol aksi khusus di modal). Field yang boleh diubah
    // dibatasi ketat per transisi supaya staff tidak bisa menyelipkan field
    // lain (mis. langsung set completed atau ganti assignedToUid).
    // Kepemilikan dicek lewat beberapa kemungkinan nama field (aplikasi ini
    // konsisten pakai reportedByUid, field lain + email sebagai jaring
    // pengaman kalau ada data/alur lain yang beda nama field).
    function isIssueTicketReporter(data) {
      return isSignedIn() && (
        data.get("reportedByUid", "") == request.auth.uid ||
        data.get("createdByUid", "") == request.auth.uid ||
        data.get("reporterUid", "") == request.auth.uid ||
        data.get("createdByEmail", "") == request.auth.token.email ||
        data.get("reporterEmail", "") == request.auth.token.email
      );
    }

    function isReporterAllowedIssueUpdate() {
      let isOwner = isIssueTicketReporter(resource.data);
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let commonKeys = ["status", "statusLabel", "staffStatusLabel",
        "lastActivityAt", "lastActivityByUid", "lastActivityByName", "lastActivityMessage",
        "updatedAt", "updatedByUid", "updatedByName"];

      let completingInfo = resource.data.status == "need_more_info" &&
        request.resource.data.status == "under_review" &&
        changed.hasOnly(commonKeys.concat(["description", "photoUrls", "attachmentUrls", "attachmentFiles"]));

      // Section C — pelapor konfirmasi kendala selesai.
      let confirmingDone = resource.data.status == "waiting_reporter_confirmation" &&
        request.resource.data.status == "reporter_confirmed" &&
        changed.hasOnly(commonKeys.concat(["reporterConfirmedAt", "reporterConfirmedByUid",
          "reporterConfirmedByName", "reporterConfirmationNote"]));

      // Section D — pelapor menyatakan masih bermasalah (field TERPISAH
      // dari reopenNote/reopenedAt milik aksi QHSE "Buka Kembali").
      let stillProblem = resource.data.status == "waiting_reporter_confirmation" &&
        request.resource.data.status == "needs_follow_up" &&
        changed.hasOnly(commonKeys.concat(["reporterRejectedResolutionAt", "reporterRejectedResolutionByUid",
          "reporterRejectedResolutionByName", "reporterRejectedResolutionNote", "reporterRejectedResolutionPhotoUrls"]));

      return isOwner && (completingInfo || confirmingDone || stillProblem);
    }

    // asset_issue_tickets: laporan kendala dari Scan QR/manual web (staff) sampai ditangani
    // Tim IT. Staff hanya boleh membuat tiket miliknya sendiri
    // dan membaca semua tiket (dibatasi query "reportedByUid == uid" di client
    // untuk /my-reports); status/diagnosa hanya boleh diubah oleh manager.
    match /asset_issue_tickets/{ticketId} {
      // READ dibuka untuk siapa saja yang login (isSignedIn()), TERMASUK
      // staff HRP fallback yang belum punya dokumen asset_users sama sekali
      // (lihat isActiveAssetUser()) — mereka tetap harus bisa buka /my-reports
      // untuk lihat laporan yang mereka buat sendiri. QHSE/Admin/IT tetap
      // bisa baca semua laporan.
      allow get, list: if isSignedIn()
        && (
          canViewAssetMaintenance()
          || resource.data.createdByUid == request.auth.uid
          || resource.data.reportedByUid == request.auth.uid
        );
      // QHSE/Super Admin boleh membuat ticket "tugas lanjutan" dari temuan
      // maintenance dengan reportedByUid = Tim IT yang menemukan (bukan
      // dirinya sendiri) — dibedakan lewat source == "maintenance_finding".
      // isManualWebIssueCreate() sengaja HANYA butuh isSignedIn() (bukan
      // isActiveAssetUser()) supaya staff HRP fallback tetap bisa submit
      // Buat Laporan walau belum punya dokumen asset_users.
      allow create: if isManualWebIssueCreate() ||
        (isActiveAssetUser() &&
          (request.resource.data.reportedByUid == request.auth.uid ||
            (isManager() && request.resource.data.source == "maintenance_finding")));
      // Section D/G — staff pelapor (termasuk HRP fallback) HANYA boleh
      // mengubah statusnya sendiri lewat 3 transisi yang tombolnya ada di
      // IssueTicketDetailModal (lib/issueTicketActions.ts): melengkapi info,
      // konfirmasi selesai, atau menyatakan masih bermasalah. TIDAK BOLEH
      // langsung set status "completed" atau field lain milik QHSE/tim.
      allow update: if isManager() || isAssetViewItTeam() || isReporterAllowedIssueUpdate();
      allow delete: if isSuperAdmin();
    }

    match /asset_issue_logs/{logId} {
      allow read: if isActiveAssetUser();
      allow create: if isActiveAssetUser();
      allow update, delete: if false;
    }

    // Log laporan kendala staff — ditulis SAAT laporan dibuat/diubah, jadi
    // create HARUS bisa dipakai staff HRP fallback juga (bukan cuma
    // canViewAssetMaintenance()), selama createdByUid cocok dengan dirinya.
    match /asset_issue_ticket_logs/{logId} {
      allow get, list: if isSignedIn()
        && (
          canViewAssetMaintenance()
          || resource.data.createdByUid == request.auth.uid
          || resource.data.reporterUid == request.auth.uid
        );
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    match /asset_activity_logs/{logId} {
      allow get, list: if canViewAssetMaintenance();
      allow create: if canViewAssetMaintenance();
      allow update, delete: if isSuperAdmin();
    }

    // asset_maintenance_work_orders: jadwal dibuat oleh Asset Admin/QHSE,
    // dikerjakan oleh Tim IT yang menjadi assignedToUid.
    match /asset_maintenance_work_orders/{workOrderId} {
      allow get, list: if canViewAssetMaintenance();

      allow create: if canEditMaintenanceSchedule();

      // Section K — status hanya boleh berubah lewat transisi yang valid
      // untuk role tersebut (isQhseRoutineStatusUpdate/isItRoutineStatusUpdate);
      // edit field lain (bukan status) tetap mengikuti aturan lama supaya alur
      // edit jadwal QHSE dan update lapangan Tim IT tidak ikut terkunci.
      allow update: if isAssetViewSuperAdmin()
        || isAssetBootstrapSuperAdminEmail()
        || isQhseRoutineStatusUpdate()
        || (isTechnicianMaintenanceUpdate() && (
          request.resource.data.get("status", "") == resource.data.get("status", "")
          || isItRoutineStatusUpdate()
        ))
        || (canEditMaintenanceSchedule() && request.resource.data.get("status", "") == resource.data.get("status", ""));

      allow delete: if canEditMaintenanceSchedule();

      match /items/{itemId} {
        allow get, list: if canViewAssetMaintenance();

        allow create, update: if canEditMaintenanceSchedule()
          || isAssignedMaintenanceTechnician(
            get(/databases/$(database)/documents/asset_maintenance_work_orders/$(workOrderId)).data
          );

        allow delete: if canEditMaintenanceSchedule();
      }
    }

    // collectionGroup(db, "items") dipakai halaman Maintenance & Reports
    // untuk membaca item work order lintas dokumen parent.
    match /{path=**}/items/{itemId} {
      allow get, list: if canViewAssetMaintenance();
      allow create, update, delete: if false;
    }

    match /asset_maintenance_work_order_logs/{logId} {
      allow read: if canViewAssetMaintenance();
      allow create: if canViewAssetMaintenance();
      allow update, delete: if false;
    }

    // asset_maintenance_activity_logs: log lintas-sumber (work order ATAU
    // ticket) untuk perpindahan status di Kanban Board Maintenance &
    // Kendala — dibaca oleh Timeline Global. Sengaja pakai izin yang sama
    // dengan canViewAssetMaintenance(), BUKAN dibuka untuk staff umum.
    match /asset_maintenance_activity_logs/{logId} {
      allow get, list: if canViewAssetMaintenance();
      allow create: if canViewAssetMaintenance();
      allow update, delete: if isSuperAdmin();
    }

    // asset_notifications: siapa saja yang aktif boleh membuat notifikasi
    // (staff lapor kendala men-trigger notifikasi ke QHSE, dst). Recipient
    // hanya boleh membaca/menandai-dibaca notifikasi miliknya sendiri.
    // READ/CREATE sengaja pakai isSignedIn() (bukan isActiveAssetUser())
    // supaya staff HRP fallback yang belum punya dokumen asset_users tetap
    // bisa memicu notifikasi ke QHSE saat submit Buat Laporan, dan tetap
    // bisa baca notifikasi miliknya sendiri.
    match /asset_notifications/{notificationId} {
      allow get, list: if isSignedIn() && (
        isSuperAdmin() ||
        resource.data.recipientUid == request.auth.uid ||
        (canViewAssetMaintenance() && resource.data.keys().hasAny(["dedupeKey"]))
      );
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() ||
        (isSignedIn() &&
          resource.data.recipientUid == request.auth.uid &&
          request.resource.data.recipientUid == resource.data.recipientUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead", "status", "readAt", "updatedAt"]));
      allow delete: if isSuperAdmin();
    }

    // asset_notification_tokens: token push milik masing-masing user, tidak
    // boleh dibaca/diubah user lain. Super Admin boleh list untuk debugging.
    match /asset_notification_tokens/{tokenId} {
      allow read: if isSuperAdmin() ||
        (isActiveAssetUser() && resource.data.uid == request.auth.uid);
      allow create: if isActiveAssetUser() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isActiveAssetUser() && resource.data.uid == request.auth.uid;
    }

    // Passkey/WebAuthn credential dan challenge hanya boleh diakses via
    // Next.js API route dengan Firebase Admin. Data biometrik TIDAK disimpan
    // di sini; collection ini hanya berisi public credential yang aman.
    match /passkey_credentials/{credentialId} {
      allow read, write: if false;
    }

    match /passkey_challenges/{challengeId} {
      allow read, write: if false;
    }

    // asset_report_snapshots: snapshot bulanan Reports & Analytics, dibuat
    // oleh Super Admin/Asset Admin dari halaman /reports.
    match /asset_report_snapshots/{snapshotId} {
      allow read: if isActiveAssetUser();
      allow create: if isManager();
      allow update, delete: if false;
    }
  }
}

rules_version = '2';

// Storage rules AssetView — hanya untuk path assets/**.
// Gabungkan blok ini ke storage.rules HRP yang sudah ada, jangan menimpanya.
service firebase.storage {
  match /b/{bucket}/o {
    match /assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.resource.size < 15 * 1024 * 1024;
    }
  }
}
